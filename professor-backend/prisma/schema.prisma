generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////
// ENUMS
//////////////////////////////////////

enum UserRole {
  OWNER
  USER
}

enum InvoiceStatus {
  DRAFT
  FINALIZED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum DiscountType {
  FIXED
  PERCENT
}

enum AdjustmentType {
  DISCOUNT
  EXTRA
}

//////////////////////////////////////
// NEW
//////////////////////////////////////

model Currency {
  id Int @id @default(autoincrement())

  code   String @unique
  name   String
  symbol String

  tenants Tenant[]

  universities University[]

  universitySubjects UniversitySubject[]

  invoices Invoice[]

  plans Plan[]
}

//////////////////////////////////////
// CORE
//////////////////////////////////////

model Tenant {
  id            Int     @id @default(autoincrement())
  legalName     String
  displayName   String?
  email         String
  phone         String?
  addressLine   String?
  city          String?
  country       String?
  taxNumber     String?
  licenseNumber String?
  bankName      String?
  iban          String?
  swiftCode     String?

  baseCurrencyId Int

  vatEnabled       Boolean  @default(false)
  vatRate          Decimal? @db.Decimal(5, 2)
  vatExemptionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  baseCurrency Currency @relation(fields: [baseCurrencyId], references: [id])

  users              User[]
  universities       University[]
  subjects           Subject[]
  universitySubjects UniversitySubject[]
  classGroups        ClassGroup[]
  subscriptions      Subscription[]

  teachingSessions  TeachingSession[]
  serviceTypes      ServiceType[]
  serviceActivities ServiceActivity[]

  invoices           Invoice[]
  invoiceAdjustments InvoiceAdjustment[]
  payments           Payment[]
  creditNotes        CreditNote[]
  auditLogs          AuditLog[]
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  role         UserRole @default(OWNER)
  isActive     Boolean  @default(true)
  fullName     String
  tenantId     Int
  createdAt    DateTime @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]
}

//////////////////////////////////////
// ACADEMIC STRUCTURE
//////////////////////////////////////

model University {
  id   Int    @id @default(autoincrement())
  name String

  defaultCurrencyId Int

  addressLine        String?
  city               String?
  country            String?
  contactEmail       String?
  contactPhone       String?
  registrationNumber String?
  taxNumber          String?

  tenantId  Int
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  defaultCurrency Currency @relation(fields: [defaultCurrencyId], references: [id])

  universitySubjects UniversitySubject[]
  serviceActivities  ServiceActivity[]
  invoices           Invoice[]

  @@unique([tenantId, name])
}

model Subject {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  tenantId    Int
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  universitySubjects UniversitySubject[]

  @@unique([tenantId, name])
}

model UniversitySubject {
  id Int @id @default(autoincrement())

  universityId Int
  subjectId    Int

  ratePerSession Decimal @db.Decimal(10, 2)

  currencyId Int

  tenantId Int

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  currency Currency @relation(fields: [currencyId], references: [id])

  classGroups      ClassGroup[]
  teachingSessions TeachingSession[]

  @@unique([universityId, subjectId])
}

model ClassGroup {
  id Int @id @default(autoincrement())

  name String

  universitySubjectId Int

  tenantId Int

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  universitySubject UniversitySubject @relation(fields: [universitySubjectId], references: [id], onDelete: Cascade)

  teachingSessions TeachingSession[]

  @@unique([universitySubjectId, name])
}

//////////////////////////////////////
// FINANCIAL WORK RECORDS
//////////////////////////////////////

model TeachingSession {
  id Int @id @default(autoincrement())

  date DateTime

  quantity Decimal @db.Decimal(10, 2)

  unitRate Decimal @db.Decimal(10, 2)

  totalAmount Decimal @db.Decimal(12, 2)

  universitySubjectId Int
  
  classGroupId Int

  invoiceId Int?

  tenantId Int

  createdAt DateTime @default(now())

  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  universitySubject UniversitySubject @relation(fields: [universitySubjectId], references: [id], onDelete: Restrict)

  classGroup ClassGroup @relation(fields: [classGroupId], references: [id], onDelete: Restrict)

  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([invoiceId])
  @@index([date])
}

model ServiceType {
  id Int @id @default(autoincrement())

  name String

  tenantId Int

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  serviceActivities ServiceActivity[]

  @@unique([tenantId, name])
}

model ServiceActivity {
  id Int @id @default(autoincrement())

  date DateTime

  quantity Decimal? @db.Decimal(10, 2)

  unitRate Decimal @db.Decimal(10, 2)

  totalAmount Decimal @db.Decimal(12, 2)

  serviceTypeId Int

  universityId Int

  invoiceId Int?

  tenantId Int

  createdAt DateTime @default(now())

  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  serviceType ServiceType @relation(fields: [serviceTypeId], references: [id], onDelete: Restrict)

  university University @relation(fields: [universityId], references: [id], onDelete: Restrict)

  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([invoiceId])
  @@index([date])
}

//////////////////////////////////////
// INVOICING
//////////////////////////////////////

model Invoice {
  id Int @id @default(autoincrement())

  invoiceNumber String

  invoiceYear Int

  invoiceSequence Int

  issueDate DateTime

  periodStart DateTime

  periodEnd DateTime

  dueDate DateTime?

  deletedAt DateTime?

  currencyId Int

  exchangeRateToBase Decimal @db.Decimal(18, 6)

  subtotal Decimal @db.Decimal(12, 2)

  discountType DiscountType?

  discountValue Decimal? @db.Decimal(12, 2)

  discountAmount Decimal? @db.Decimal(12, 2)

  vatRateSnapshot Decimal? @db.Decimal(5, 2)

  vatAmount Decimal? @db.Decimal(12, 2)

  totalAmount Decimal @db.Decimal(12, 2)

  totalAmountBase Decimal @db.Decimal(14, 2)

  status InvoiceStatus @default(DRAFT)

  paymentStatus PaymentStatus @default(UNPAID)

  universityId Int

  tenantId Int

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  university University @relation(fields: [universityId], references: [id])

  currency Currency @relation(fields: [currencyId], references: [id])

  teachingSessions TeachingSession[]

  serviceActivities ServiceActivity[]

  adjustments InvoiceAdjustment[]

  payments Payment[]

  creditNotes CreditNote[]

  @@unique([tenantId, invoiceYear, invoiceSequence])
  @@index([tenantId])
  @@index([universityId])
  @@index([status])
  @@index([issueDate])
}

model InvoiceAdjustment {
  id Int @id @default(autoincrement())

  type AdjustmentType

  description String

  amount Decimal @db.Decimal(12, 2)

  invoiceId Int

  tenantId Int

  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Payment {
  id Int @id @default(autoincrement())

  amount Decimal @db.Decimal(12, 2)

  amountBase Decimal @db.Decimal(14, 2)

  paymentDate DateTime

  method String?

  referenceNumber String?

  invoiceId Int

  tenantId Int

  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model CreditNote {
  id Int @id @default(autoincrement())

  totalAmount Decimal @db.Decimal(12, 2)

  reason String

  invoiceId Int

  tenantId Int

  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model AuditLog {
  id Int @id @default(autoincrement())

  entityType String

  entityId Int

  action String

  userId Int

  tenantId Int

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Plan {
  id Int @id @default(autoincrement())

  name String

  priceMonthly Decimal @db.Decimal(10, 2)

  currencyId Int

  createdAt DateTime @default(now())

  currency Currency @relation(fields: [currencyId], references: [id])

  subscriptions Subscription[]
}

model Subscription {
  id Int @id @default(autoincrement())

  tenantId Int

  planId Int

  startDate DateTime

  endDate DateTime

  isActive Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  plan Plan @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())

  @@index([tenantId])
}
